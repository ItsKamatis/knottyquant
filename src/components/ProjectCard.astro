---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'projects'>;
  compact?: boolean;
}

const { entry, compact = false } = Astro.props;
const { data } = entry;
---

<article class:list={['research-card', { compact }]}>
  <a class="research-card-media" href={`/${data.slug}.html`} aria-label={`Read ${data.title}`}>
    <img
      src={data.heroImage}
      width={data.heroWidth}
      height={data.heroHeight}
      alt={data.heroAlt}
      loading="lazy"
      decoding="async"
    />
  </a>
  <div class="research-card-copy">
    <p class="eyebrow">Research project</p>
    <h3><a href={`/${data.slug}.html`}>{data.title}</a></h3>
    <p>{data.summary}</p>
    <p class="boundary-line"><strong>Data boundary:</strong> {data.dataBoundary}</p>
    <ul class="tag-list" aria-label="Techniques">
      {data.techniques.slice(0, compact ? 4 : 6).map((technique) => <li>{technique}</li>)}
    </ul>
    <a class="text-link" href={`/${data.slug}.html`}>Read the project <span aria-hidden="true">→</span></a>
  </div>
</article>
