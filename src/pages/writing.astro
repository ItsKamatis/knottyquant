---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entries = (await getCollection('writing'))
  .filter(({ data }) => data.status === 'published')
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime());

const formatDate = (date: Date) => new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'UTC',
}).format(date);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'KnottyQuant writing',
  url: 'https://knottyquant.com/writing.html',
  description: 'Writing on quantitative finance, topology, model evidence, and research practice.',
};
---

<BaseLayout
  title="Writing"
  description="KnottyQuant writing on quantitative finance, topology, model evidence, and research practice."
  canonicalPath="/writing.html"
  structuredData={structuredData}
>
  <header class="page-hero page-shell">
    <p class="eyebrow">Writing</p>
    <h1>Notes on methods and evidence.</h1>
    <p>Longer explanations of technical ideas, with a clear distinction between established results and open research questions.</p>
  </header>

  <section class="index-section page-shell" aria-labelledby="writing-list-title">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Essays</p>
        <h2 id="writing-list-title">It's really more of a blog...</h2>
      </div>
    </div>
    {entries.map(({ data }) => (
      <article class="writing-entry">
        <div>
          <p class="eyebrow">{formatDate(data.published)}</p>
          <ul class="tag-list" aria-label="Topics">
            {data.topics.map((topic) => <li>{topic}</li>)}
          </ul>
        </div>
        <div>
          <h2><a href={`/writing/${data.slug}.html`}>{data.title}</a></h2>
          <p>{data.summary}</p>
          <a class="text-link" href={`/writing/${data.slug}.html`}>Read the essay <span aria-hidden="true">→</span></a>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
