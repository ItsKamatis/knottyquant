---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const papers = (await getCollection('papers')).sort(
  (a, b) => b.data.published.getTime() - a.data.published.getTime(),
);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'KnottyQuant research',
  url: 'https://knottyquant.com/research.html',
  description: 'Research projects in derivatives, portfolio construction, risk, and numerical methods.',
};
---

<BaseLayout
  title="Research"
  description="KnottyQuant research in interest-rate derivatives, portfolio construction, volatility calibration, risk, and numerical methods."
  canonicalPath="/research.html"
  structuredData={structuredData}
>
  <header class="page-hero page-shell">
    <p class="eyebrow">Research</p>
    <h1>Methods, implementation, and checks.</h1>
    <p>Each project states its data boundary, assumptions, numerical approach, evidence, and limitations.</p>
  </header>

  <section class="index-section page-shell" aria-labelledby="projects-title">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Projects</p>
        <h2 id="projects-title">Current research</h2>
      </div>
    </div>
    <div class="research-grid">
      {projects.map((entry) => <ProjectCard entry={entry} />)}
    </div>
  </section>

  <section class="index-section page-shell" aria-labelledby="papers-title">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Papers</p>
        <h2 id="papers-title">Technical notes</h2>
      </div>
    </div>
    {papers.map(({ data }) => (
      <article class="paper-entry">
        <div>
          <p class="eyebrow">{data.published.getUTCFullYear()} · {data.pages} pages</p>
          <a class="text-link" href={`/${data.supportingProject}.html`}>Supporting project</a>
        </div>
        <div>
          <h2><a href={data.pdfUrl}>{data.title}</a></h2>
          <p>{data.summary}</p>
          <ul class="tag-list" aria-label="Topics">
            {data.topics.map((topic) => <li>{topic}</li>)}
          </ul>
          <a class="text-link" href={data.pdfUrl}>Read the PDF <span aria-hidden="true">→</span></a>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
